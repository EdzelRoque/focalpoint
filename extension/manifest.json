{
    "manifest_version": 3,
    "name": "FocalPoint",
    "version": "1.0",
    "description": "AI-powered focus assistant that understands your goals.",
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:3000/*"
    ]
}